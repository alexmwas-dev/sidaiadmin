# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Set to "demo" to enable demo-mode restrictions (e.g. read-only settings).
APP_FOR=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
ASSET_URL=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DB_FOREIGN_KEYS=true
# Full URL override (optional): mysql://user:pass@host:3306/database
# DATABASE_URL=
# MYSQL_ATTR_SSL_CA=  # Path to CA cert if using SSL

# -----------------------------------------------------------------------------
# Session & Cookie
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_CONNECTION=
SESSION_STORE=

# -----------------------------------------------------------------------------
# Cache (file, database, redis, memcached, etc.)
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_PREFIX=

# -----------------------------------------------------------------------------
# Queue (sync, database, redis, sqs)
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=database
REDIS_QUEUE=default
QUEUE_FAILED_DRIVER=database-uuids
# SQS: SQS_PREFIX=, SQS_QUEUE=default, SQS_SUFFIX=

# -----------------------------------------------------------------------------
# File storage (default disk: local, public, s3)
# Models use FILESYSTEM_DRIVER for asset URLs; usually same as default disk.
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
FILESYSTEM_DRIVER=local

# -----------------------------------------------------------------------------
# Redis (for cache, queue, session when used)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_URL=
REDIS_USERNAME=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=
REDIS_CLUSTER=false

# -----------------------------------------------------------------------------
# Memcached (when CACHE_DRIVER=memcached)
# -----------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=
MAIL_URL=
MAIL_LOG_CHANNEL=
MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -bs -i
# Mailgun: MAILGUN_DOMAIN=, MAILGUN_SECRET=, MAILGUN_ENDPOINT=api.mailgun.net
# Postmark: POSTMARK_TOKEN=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_SLACK_WEBHOOK_URL=
LOG_PAPERTRAIL_URL=
LOG_PAPERTRAIL_PORT=
LOG_STDERR_FORMATTER=
# PAPERTRAIL_URL=, PAPERTRAIL_PORT=, LOG_PAPERTRAIL_HANDLER=

# -----------------------------------------------------------------------------
# Broadcasting (pusher, ably, redis, log, null)
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
# Pusher: PUSHER_APP_ID=, PUSHER_APP_KEY=, PUSHER_APP_SECRET=, PUSHER_APP_CLUSTER=, PUSHER_HOST=, PUSHER_PORT=443, PUSHER_SCHEME=https
# Ably: ABLY_KEY=

# -----------------------------------------------------------------------------
# AWS (S3, SQS, SES when used)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
# DynamoDB cache: DYNAMODB_CACHE_TABLE=cache, DYNAMODB_ENDPOINT=

# -----------------------------------------------------------------------------
# Hashing
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Payment gateway (e.g. stripe, paypal) – used by API/controllers
# -----------------------------------------------------------------------------
PAYMENT_GATEWAY=stripe

# Stripe (config/services.php, config/stripe.php)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300

# PayPal (config/paypal.php)
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_SANDBOX_APP_ID=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_APP_ID=
PAYPAL_PAYMENT_ACTION=Sale
PAYPAL_CURRENCY=USD
PAYPAL_NOTIFY_URL=
PAYPAL_LOCALE=en_US
PAYPAL_VALIDATE_SSL=true

# -----------------------------------------------------------------------------
# Firebase (push, OTP, real-time) – credentials path + project
# Service account JSON path; can use GOOGLE_APPLICATION_CREDENTIALS instead.
# -----------------------------------------------------------------------------
FIREBASE_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS=
# Firebase DB URL is often stored in DB (third_party_settings.firebase_database_url). Optional override:
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT=app
FIREBASE_AUTH_TENANT_ID=
FIREBASE_STORAGE_DEFAULT_BUCKET=
FIREBASE_DYNAMIC_LINKS_DEFAULT_DOMAIN=
FIREBASE_CACHE_STORE=file
FIREBASE_HTTP_LOG_CHANNEL=
FIREBASE_HTTP_DEBUG_LOG_CHANNEL=
FIREBASE_HTTP_CLIENT_PROXY=
FIREBASE_HTTP_CLIENT_TIMEOUT=

# -----------------------------------------------------------------------------
# Push notifications (FCM)
# -----------------------------------------------------------------------------
FCM_SERVER_KEY=

# -----------------------------------------------------------------------------
# reCAPTCHA (config/services.php)
# -----------------------------------------------------------------------------
REACPTCHA_SITE_KEY=
REACPTCHA_SECRET_KEY=
ENABLE_RECAPTCHA=

# -----------------------------------------------------------------------------
# SMS (config/sms.php) – provider: log, smsindiahub, msg91, trap
# -----------------------------------------------------------------------------
SMS_PROVIDER=log
SMS_SENDER_ID=
SMSINDIAHUB_USERNAME=
SMSINDIAHUB_PASSWORD=
MSG91_AUTH_KEY=
SMS_TRAP_EMAIL=

# -----------------------------------------------------------------------------
# Sanctum (API tokens)
# -----------------------------------------------------------------------------
# SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_PREFIX=

# -----------------------------------------------------------------------------
# Scribe (API docs auth)
# -----------------------------------------------------------------------------
SCRIBE_AUTH_KEY=

# -----------------------------------------------------------------------------
# Web / SEO (config/base.php – verification & social links)
# -----------------------------------------------------------------------------
GOOGLE_VERIFICATION_KEY=
BING_VERIFICATION_KEY=
FACEBOOK_LINK=
TWITTER_LINK=
INSTAGRAM_LINK=
GOOGLEPLUS_LINK=
LINKEDIN_LINK=

# -----------------------------------------------------------------------------
# View (optional)
# -----------------------------------------------------------------------------
# VIEW_COMPILED_PATH=

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
